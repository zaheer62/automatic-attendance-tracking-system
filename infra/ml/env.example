# infra/ml/.env.example
# Copy this to .env and fill in your values

# Same PostgreSQL URL as backend — ml/train.py reads embeddings from here
DATABASE_URL=postgresql://admin:secret123@localhost:5432/attendance

# Cosine similarity threshold for a valid face match (0.0 – 1.0)
# 0.80 is a good starting point; raise to reduce false positives
CONFIDENCE_THRESHOLD=0.80
